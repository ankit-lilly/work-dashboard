# Job Viewer - Example Environment

# Comma-separated list of environments:
# format: name:profile:region (region optional; defaults to us-east-2 in this project)
# If you repeat a name with different profiles, the UI will show name:profile.
JOB_ENVS=dev:campdev:us-east-2,qa:campqa:us-east-2,prod:campprod:us-east-2,dev:dsoadev:us-east-2,qa:dsoaqa:us-east-2

# Polling intervals (Go duration strings)
JOB_ACTIVE_POLL=5s
JOB_FAILURES_POLL=120s
JOB_STATE_MACHINES_POLL=5m

# Per-environment active polling override (Go duration strings)
JOB_ACTIVE_POLL_BY_ENV=dev=10s,qa=10s,prod=30s

# ── CAMP Investigator MCP (cmd/mcp) ──────────────────────────────────────────
# Environments available to the MCP server.
# Uses same format as JOB_ENVS: name:profile:region
MCP_ENVS=dev:campdev:us-east-2,qa:campqa:us-east-2,prod:campprod:us-east-2

# AWS Secrets Manager secret ID template for DB credentials.
# %s is replaced with the environment name (e.g. "prod" → "awsrds-gdm-aurora-pgsql-accma-prod-cluster")
MCP_SECRET_ID_TEMPLATE=awsrds-gdm-aurora-pgsql-accma-%s-cluster

# Set to any non-empty value to log SQL queries executed by MCP tools (via slog).
# MCP_LOG_QUERIES=true
